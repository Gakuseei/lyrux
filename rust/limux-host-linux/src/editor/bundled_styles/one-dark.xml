<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="one-dark" _name="One Dark" version="1.0">
  <author>Lyrux (palette: Atom One Dark, MIT, GitHub Inc.)</author>
  <_description>One Dark — Atom-inspired dark theme.</_description>

  <color name="bg"        value="#282c34"/>
  <color name="bg-sel"    value="#3e4451"/>
  <color name="fg"        value="#abb2bf"/>
  <color name="fg-muted"  value="#5c6370"/>
  <color name="accent"    value="#61afef"/>
  <color name="keyword"   value="#c678dd"/>
  <color name="string"    value="#98c379"/>
  <color name="number"    value="#d19a66"/>
  <color name="comment"   value="#5c6370"/>
  <color name="type"      value="#e5c07b"/>
  <color name="function"  value="#61afef"/>
  <color name="error"     value="#e06c75"/>
  <color name="warning"   value="#d19a66"/>
  <color name="surface0"  value="#2c313a"/>

  <style name="text"                       foreground="fg"      background="bg"/>
  <style name="background-pattern"         background="bg"/>
  <style name="cursor"                     foreground="accent"/>
  <style name="current-line"               background="surface0"/>
  <style name="line-numbers"               foreground="comment" background="#22262E"/>
  <style name="current-line-number"        foreground="fg"      background="bg" bold="true"/>
  <style name="selection"                  background="bg-sel"/>
  <style name="bracket-match"              foreground="accent"  bold="true"/>
  <style name="bracket-mismatch"           foreground="error"   bold="true"/>
  <style name="right-margin"               foreground="surface0" background="surface0"/>
  <style name="search-match"               background="#3e4a35" foreground="fg"/>
  <style name="def:keyword"                foreground="keyword" bold="true"/>
  <style name="def:builtin"                foreground="type"/>
  <style name="def:type"                   foreground="type"/>
  <style name="def:string"                 foreground="string"/>
  <style name="def:number"                 foreground="number"/>
  <style name="def:comment"                foreground="comment" italic="true"/>
  <style name="def:doc-comment"            foreground="comment" italic="true"/>
  <style name="def:doc-comment-element"    foreground="comment" italic="true"/>
  <style name="def:identifier"             foreground="fg"/>
  <style name="def:function"               foreground="function"/>
  <style name="def:constant"               foreground="number"/>
  <style name="def:operator"               foreground="fg-muted"/>
  <style name="def:special-char"           foreground="number"/>
  <style name="def:preprocessor"           foreground="keyword"/>
  <style name="def:error"                  foreground="error"   underline="single"/>
  <style name="def:warning"                foreground="warning" underline="single"/>
  <style name="def:heading"                foreground="keyword"  bold="true"/>
  <style name="def:heading0"               foreground="keyword"  bold="true"/>
  <style name="def:heading1"               foreground="keyword"  bold="true"/>
  <style name="def:heading2"               foreground="accent"   bold="true"/>
  <style name="def:heading3"               foreground="function" bold="true"/>
  <style name="def:heading4"               foreground="type"     bold="true"/>
  <style name="def:heading5"               foreground="string"   bold="true"/>
  <style name="def:heading6"               foreground="number"   bold="true"/>
  <style name="def:emphasis"               foreground="string"   italic="true"/>
  <style name="def:strong-emphasis"        foreground="function" bold="true"/>
  <style name="def:inline-code"            foreground="string"   background="surface0"/>
  <style name="def:preformatted-section"   foreground="string"   background="surface0"/>
  <style name="def:link-text"              foreground="accent"   underline="single"/>
  <style name="def:link-destination"       foreground="type"     italic="true" underline="single"/>
  <style name="def:link-symbol"            foreground="fg-muted"/>
  <style name="def:list-marker"            foreground="accent"   bold="true"/>
  <style name="def:thematic-break"         foreground="comment"/>
  <style name="def:shebang"                foreground="comment"  italic="true"/>
  <style name="def:note"                   foreground="warning"  bold="true"/>
  <style name="def:underlined"             foreground="accent"   underline="single"/>
  <style name="def:net-address"            foreground="accent"   underline="single"/>
  <style name="def:variable"               foreground="type"/>
  <style name="def:character"              foreground="string"/>
  <style name="def:boolean"                foreground="number"   bold="true"/>
  <style name="def:floating-point"         foreground="number"/>
  <style name="def:base-n-integer"         foreground="number"/>
  <style name="def:insertion"              foreground="string"   underline="single"/>
  <style name="def:deletion"               foreground="error"    strikethrough="true"/>
</style-scheme>
