<?xml version="1.0" encoding="UTF-8"?>
<style-scheme id="catppuccin-frappe" _name="Catppuccin Frappé" version="1.0">
  <author>Lyrux (palette: Catppuccin Org, MIT)</author>
  <_description>Catppuccin Frappé — cool dark theme.</_description>

  <color name="bg"        value="#303446"/>
  <color name="bg-sel"    value="#51576d"/>
  <color name="fg"        value="#c6d0f5"/>
  <color name="fg-muted"  value="#838ba7"/>
  <color name="accent"    value="#8caaee"/>
  <color name="keyword"   value="#ca9ee6"/>
  <color name="string"    value="#a6d189"/>
  <color name="number"    value="#ef9f76"/>
  <color name="comment"   value="#838ba7"/>
  <color name="type"      value="#e5c890"/>
  <color name="function"  value="#8caaee"/>
  <color name="error"     value="#e78284"/>
  <color name="warning"   value="#ef9f76"/>
  <color name="surface0"  value="#414559"/>

  <style name="text"                       foreground="fg"      background="bg"/>
  <style name="background-pattern"         background="bg"/>
  <style name="cursor"                     foreground="accent"/>
  <style name="current-line"               background="surface0"/>
  <style name="line-numbers"               foreground="comment" background="#2A2D3D"/>
  <style name="current-line-number"        foreground="fg"      background="bg" bold="true"/>
  <style name="selection"                  background="bg-sel"/>
  <style name="bracket-match"              foreground="accent"  bold="true"/>
  <style name="bracket-mismatch"           foreground="error"   bold="true"/>
  <style name="right-margin"               foreground="surface0" background="surface0"/>
  <style name="search-match"               background="#45475a" foreground="fg"/>
  <style name="def:keyword"                foreground="keyword" bold="true"/>
  <style name="def:builtin"                foreground="type"/>
  <style name="def:type"                   foreground="type"/>
  <style name="def:string"                 foreground="string"/>
  <style name="def:number"                 foreground="number"/>
  <style name="def:comment"                foreground="comment" italic="true"/>
  <style name="def:doc-comment"            foreground="comment" italic="true"/>
  <style name="def:doc-comment-element"    foreground="comment" italic="true"/>
  <style name="def:identifier"             foreground="fg"/>
  <style name="def:function"               foreground="function"/>
  <style name="def:constant"               foreground="number"/>
  <style name="def:operator"               foreground="fg-muted"/>
  <style name="def:special-char"           foreground="number"/>
  <style name="def:preprocessor"           foreground="keyword"/>
  <style name="def:error"                  foreground="error"   underline="single"/>
  <style name="def:warning"                foreground="warning" underline="single"/>
</style-scheme>
